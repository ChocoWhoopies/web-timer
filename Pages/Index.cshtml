@page "{id?}"
@model IndexModel
@{
    ViewData["Title"] = "Shared Timer";

    var exampleRoomId = $"room-{Guid.NewGuid().ToString("N")[..6]}";
}

<div class="text-center">
    @if (string.IsNullOrEmpty(Model.SessionId))
    {
        <div class="mt-2 p-4 landing-panel d-flex flex-column">
            <div>
                <h3>Welcome to Shared Timer</h3>
                <p>To start a session, simply add a name to the URL.</p>
                <p class="mb-1">
                Example:
                <a href="@($"/{exampleRoomId}")"><code>@Request.Host/@exampleRoomId</code></a>
                </p>
                <br />
                <p class="mb-0">This will create a new timer session that anyone can join and control by visiting the same URL.</p>
            </div>
            <p class="mt-auto mb-0 pt-5 landing-source-link">
                Source code:
                <a href="https://github.com/ChocoWhoopies/web-timer" target="_blank" rel="noreferrer">github.com/ChocoWhoopies/web-timer</a>
            </p>
        </div>
    }
    else
    {
        <div class="timer-display-controls">
            <button onclick="handleAdjustTime(-30)" class="btn btn-lg timer-adjust-button" type="button" aria-label="Subtract 30 seconds" title="Subtract 30 seconds">
                <span aria-hidden="true">-</span>
            </button>
            <div id="timerDisplay">00:00</div>
            <button onclick="handleAdjustTime(30)" class="btn btn-lg timer-adjust-button" type="button" aria-label="Add 30 seconds" title="Add 30 seconds">
                <span aria-hidden="true">+</span>
            </button>
        </div>
        <div class="mt-2 d-flex justify-content-center align-items-center gap-2">
            <button id="shareRoomButton" type="button" class="btn btn-sm btn-outline-light room-action-button" title="Copy room ID" aria-label="Copy room ID">
                <span class="room-action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M15 5a3 3 0 1 1 2.83 4H17l-6.2 3.1a3 3 0 0 1 0 1.8L17 17h.83A3 3 0 1 1 15 21a3 3 0 0 1 .17-1H15l-6.2-3.1a3 3 0 1 1 0-9.8L15 4h.17A3 3 0 0 1 15 5Z" fill="currentColor" />
                    </svg>
                </span>
            </button>
            <button id="notificationToggle" type="button" class="btn btn-sm btn-outline-light" title="Toggle timer sound" aria-label="Toggle timer sound">
                🔔
            </button>
            <span id="signalrIndicator" class="signalr-indicator signalr-disconnected" title="Disconnected"></span>
        </div>
        <div class="mt-2 mb-3 small text-white-50">Connected to this room: <span id="roomUserCount">0</span></div>
        <details class="alarm-panel mt-3 mx-auto p-3">
            <summary class="small text-uppercase alarm-panel-title">Personal Alarm</summary>
            <div class="d-flex justify-content-center align-items-end gap-2 flex-wrap mt-3">
                <div>
                    <label class="small d-block" for="alarmMinInput">Notify at minutes left</label>
                    <input type="number" id="alarmMinInput" value="0" min="0" class="form-control text-center alarm-input">
                </div>
                <div>
                    <label class="small d-block" for="alarmSecInput">Seconds</label>
                    <input type="number" id="alarmSecInput" value="5" min="0" max="59" class="form-control text-center alarm-input">
                </div>
                <button id="alarmSaveButton" type="button" class="btn btn-sm btn-outline-light">Save alarm</button>
            </div>
            <div id="alarmStatus" class="small mt-2 text-white-50">This alarm only applies in this browser.</div>
            <div class="alarm-sound-settings mt-3 pt-3">
                <label class="small d-block mb-2" for="alarmSoundInput">Personal sound file</label>
                <input type="file" id="alarmSoundInput" accept="audio/*" class="form-control form-control-sm" />
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                    <button id="alarmSoundTestButton" type="button" class="btn btn-sm btn-outline-light">Test sound</button>
                    <button id="alarmSoundResetButton" type="button" class="btn btn-sm btn-outline-light">Use default sound</button>
                </div>
                <div id="alarmSoundStatus" class="small mt-2 text-white-50">Using default alarm sound.</div>
            </div>
        </details>
        <details class="alarm-panel mt-3 mx-auto p-3">
            <summary class="small text-uppercase alarm-panel-title">Shared Controls</summary>
            <div class="small mt-2 text-white-50">These controls affect the timer for everyone in this room.</div>
            <div class="controls mt-3 p-0">
                <div class="btn-group flex-wrap justify-content-center mb-3" role="group" aria-label="Shared timer controls">
                    <button onclick="handlePause()" class="btn btn-lg shared-control-icon-button" type="button" aria-label="Pause or resume timer" title="Pause or resume timer">
                        <span class="timer-action-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <path d="M7 5h3v14H7zM14 5h3v14h-3z" fill="currentColor" />
                            </svg>
                        </span>
                    </button>
                    <button onclick="handleReset()" class="btn btn-lg shared-control-icon-button" type="button" aria-label="Reset timer" title="Reset timer">
                        <span class="timer-action-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <path d="M12 5a7 7 0 1 1-6.6 4.7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                                <path d="M5 5v5h5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    </button>
                </div>

                <div id="timerPresetRows" class="timer-preset-rows" aria-label="Timer presets">
                    <div class="timer-preset-row" data-timer-row>
                        <div class="timer-preset-field">
                            <label class="small d-block" for="timerMinInput-0">Minutes</label>
                            <input type="number" id="timerMinInput-0" value="5" min="0" class="form-control text-center timer-preset-input" data-minutes-input>
                        </div>
                        <div class="timer-preset-field">
                            <label class="small d-block" for="timerSecInput-0">Seconds</label>
                            <input type="number" id="timerSecInput-0" value="0" min="0" max="59" class="form-control text-center timer-preset-input" data-seconds-input>
                        </div>
                        <button class="btn btn-lg timer-preset-start" type="button" data-start-timer aria-label="Start timer" title="Start timer">
                            <span class="timer-preset-start-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M8 6v12l10-6z" fill="currentColor" />
                                </svg>
                            </span>
                        </button>
                        <button class="btn btn-lg timer-preset-remove" type="button" data-remove-timer-row aria-label="Remove timer row" title="Remove timer row">
                            <span class="timer-action-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                                </svg>
                            </span>
                        </button>
                    </div>
                </div>

                <button id="addTimerRowButton" class="btn btn-lg timer-preset-add mt-3" type="button" aria-label="Add new timer row" title="Add new timer row">
                    <span class="timer-action-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </span>
                </button>
            </div>
        </details>
    }
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<script>
    // 1. Get the SessionId from the C# Model
    const currentRoomId = "@Model.SessionId";
    const notificationStorageKey = "webtimer.notifications.disabled";
    const defaultAlarmThresholdInSeconds = 5;
    const defaultFinishSoundUrl = "/audio/notification-tone_short.mp3";
    const alarmSoundDatabaseName = "WebTimerPersonalAudio";
    const alarmSoundStoreName = "alarmSoundFiles";
    const alarmStorageKey = currentRoomId
        ? `webtimer.alarm.threshold:${currentRoomId}`
        : "webtimer.alarm.threshold:default";
    const alarmSoundStorageKey = currentRoomId
        ? `webtimer.alarm.sound:${currentRoomId}`
        : "webtimer.alarm.sound:default";

    let finishSoundUnlocked = false;
    let customFinishSoundUrl = null;

    function normalizeAlarmSeconds(totalSeconds) {
        return Math.max(0, Math.floor(Number.isFinite(totalSeconds) ? totalSeconds : 0));
    }

    function getAlarmThresholdInSeconds() {
        const savedValue = parseInt(localStorage.getItem(alarmStorageKey), 10);
        if (Number.isNaN(savedValue)) {
            return defaultAlarmThresholdInSeconds;
        }

        return normalizeAlarmSeconds(savedValue);
    }

    function setAlarmThresholdInSeconds(totalSeconds) {
        localStorage.setItem(alarmStorageKey, normalizeAlarmSeconds(totalSeconds).toString());
    }

    function formatAlarmTime(totalSeconds) {
        const safeSeconds = normalizeAlarmSeconds(totalSeconds);
        const minutes = Math.floor(safeSeconds / 60).toString().padStart(2, "0");
        const seconds = (safeSeconds % 60).toString().padStart(2, "0");
        return `${minutes}:${seconds}`;
    }

    function getAlarmInputElements() {
        return {
            minutesInput: document.getElementById("alarmMinInput"),
            secondsInput: document.getElementById("alarmSecInput"),
            status: document.getElementById("alarmStatus")
        };
    }

    function getAlarmSoundElements() {
        return {
            input: document.getElementById("alarmSoundInput"),
            testButton: document.getElementById("alarmSoundTestButton"),
            resetButton: document.getElementById("alarmSoundResetButton"),
            status: document.getElementById("alarmSoundStatus")
        };
    }

    function syncAlarmInputs() {
        const { minutesInput, secondsInput } = getAlarmInputElements();
        if (!minutesInput || !secondsInput) {
            return;
        }

        const alarmThresholdInSeconds = getAlarmThresholdInSeconds();
        minutesInput.value = Math.floor(alarmThresholdInSeconds / 60).toString();
        secondsInput.value = (alarmThresholdInSeconds % 60).toString();
    }

    function updateAlarmStatus(message) {
        const { status } = getAlarmInputElements();
        if (!status) {
            return;
        }

        status.innerText = message || `Alarm set for ${formatAlarmTime(getAlarmThresholdInSeconds())} remaining.`;
    }

    function updateAlarmSoundStatus(message) {
        const { status } = getAlarmSoundElements();
        if (!status) {
            return;
        }

        status.innerText = message;
    }

    function revokeCustomFinishSoundUrl() {
        if (!customFinishSoundUrl) {
            return;
        }

        URL.revokeObjectURL(customFinishSoundUrl);
        customFinishSoundUrl = null;
    }

    function getFinishSoundElement() {
        return document.getElementById("timerFinishedSound");
    }

    function setFinishSoundSource(sourceUrl) {
        const finishSound = getFinishSoundElement();
        if (!finishSound) {
            return;
        }

        finishSound.pause();
        finishSound.currentTime = 0;
        finishSound.src = sourceUrl;
        finishSound.load();
        finishSoundUnlocked = false;
    }

    function openAlarmSoundDatabase() {
        if (!("indexedDB" in window)) {
            return Promise.resolve(null);
        }

        return new Promise((resolve, reject) => {
            const request = indexedDB.open(alarmSoundDatabaseName, 1);

            request.onupgradeneeded = () => {
                const database = request.result;
                if (!database.objectStoreNames.contains(alarmSoundStoreName)) {
                    database.createObjectStore(alarmSoundStoreName);
                }
            };

            request.onsuccess = () => {
                resolve(request.result);
            };

            request.onerror = () => {
                reject(request.error || new Error("Unable to open alarm sound storage."));
            };
        });
    }

    function runAlarmSoundTransaction(mode, executor) {
        return openAlarmSoundDatabase().then((database) => {
            if (!database) {
                return null;
            }

            return new Promise((resolve, reject) => {
                const transaction = database.transaction(alarmSoundStoreName, mode);
                const store = transaction.objectStore(alarmSoundStoreName);
                const request = executor(store);

                request.onsuccess = () => {
                    resolve(request.result ?? null);
                };

                request.onerror = () => {
                    reject(request.error || new Error("Alarm sound storage request failed."));
                };

                transaction.oncomplete = () => {
                    database.close();
                };

                transaction.onerror = () => {
                    reject(transaction.error || new Error("Alarm sound storage transaction failed."));
                };

                transaction.onabort = () => {
                    reject(transaction.error || new Error("Alarm sound storage transaction was aborted."));
                };
            });
        });
    }

    function loadStoredAlarmSound() {
        return runAlarmSoundTransaction("readonly", (store) => store.get(alarmSoundStorageKey));
    }

    function saveStoredAlarmSound(file) {
        return runAlarmSoundTransaction("readwrite", (store) => store.put({
            blob: file,
            name: file.name,
            type: file.type,
            updatedAt: Date.now()
        }, alarmSoundStorageKey));
    }

    function clearStoredAlarmSound() {
        return runAlarmSoundTransaction("readwrite", (store) => store.delete(alarmSoundStorageKey));
    }

    async function applyStoredAlarmSound(record) {
        revokeCustomFinishSoundUrl();

        if (record?.blob instanceof Blob) {
            customFinishSoundUrl = URL.createObjectURL(record.blob);
            setFinishSoundSource(customFinishSoundUrl);
            updateAlarmSoundStatus(`Using personal sound: ${record.name}. Stored only in this browser.`);
            return true;
        }

        setFinishSoundSource(defaultFinishSoundUrl);
        updateAlarmSoundStatus("Using default alarm sound.");
        return false;
    }

    async function initializeAlarmSound() {
        if (!("indexedDB" in window)) {
            setFinishSoundSource(defaultFinishSoundUrl);
            updateAlarmSoundStatus("Custom sound storage is not available in this browser. Using default alarm sound.");
            const { input, resetButton } = getAlarmSoundElements();
            if (input) {
                input.disabled = true;
            }
            if (resetButton) {
                resetButton.disabled = true;
            }
            return;
        }

        try {
            const record = await loadStoredAlarmSound();
            await applyStoredAlarmSound(record);
        } catch {
            setFinishSoundSource(defaultFinishSoundUrl);
            updateAlarmSoundStatus("Could not load a saved personal sound. Using default alarm sound.");
        }
    }

    async function ensureBrowserNotificationPermission() {
        if (!("Notification" in window)) {
            return "unsupported";
        }

        if (Notification.permission !== "default") {
            return Notification.permission;
        }

        try {
            return await Notification.requestPermission();
        } catch {
            return Notification.permission;
        }
    }

    async function saveAlarmSettings() {
        const { minutesInput, secondsInput } = getAlarmInputElements();
        if (!minutesInput || !secondsInput) {
            return;
        }

        const minutes = Math.max(0, parseInt(minutesInput.value, 10) || 0);
        const seconds = Math.min(59, Math.max(0, parseInt(secondsInput.value, 10) || 0));
        const totalSeconds = (minutes * 60) + seconds;

        minutesInput.value = minutes.toString();
        secondsInput.value = seconds.toString();

        setAlarmThresholdInSeconds(totalSeconds);
        const permission = await ensureBrowserNotificationPermission();
        const notificationSuffix = permission === "denied"
            ? " Browser notifications are blocked, so only sound will play."
            : "";

        updateAlarmStatus(`Alarm set for ${formatAlarmTime(totalSeconds)} remaining.${notificationSuffix}`);
    }

    async function tryShowBrowserNotification(totalSeconds) {
        if (!("Notification" in window) || document.visibilityState === "visible") {
            return;
        }

        if (Notification.permission === "granted") {
            new Notification("WebTimer alarm", {
                body: `Timer reached ${formatAlarmTime(totalSeconds)} remaining.`,
                silent: notificationsDisabled()
            });
            return;
        }

        if (Notification.permission !== "default") {
            return;
        }
    }

    async function primeFinishSound() {
        if (finishSoundUnlocked) {
            return true;
        }

        const finishSound = getFinishSoundElement();
        if (!finishSound) {
            return false;
        }

        const wasMuted = finishSound.muted;

        try {
            finishSound.muted = true;
            finishSound.currentTime = 0;
            await finishSound.play();
            finishSound.pause();
            finishSound.currentTime = 0;
            finishSoundUnlocked = true;
            return true;
        } catch {
            return false;
        } finally {
            finishSound.muted = wasMuted;
        }
    }

    function registerAudioUnlock() {
        const unlockAudio = async () => {
            await primeFinishSound();
        };

        document.addEventListener("pointerdown", unlockAudio, { once: true });
        document.addEventListener("keydown", unlockAudio, { once: true });
    }

    function notificationsDisabled() {
        return localStorage.getItem(notificationStorageKey) === "true";
    }

    function setNotificationsDisabled(disabled) {
        localStorage.setItem(notificationStorageKey, disabled ? "true" : "false");
    }

    function updateNotificationToggleIcon() {
        const toggleButton = document.getElementById("notificationToggle");
        if (!toggleButton) return;

        const disabled = notificationsDisabled();
        toggleButton.innerText = disabled ? "🔕" : "🔔";
        toggleButton.title = disabled ? "Sound disabled" : "Sound enabled";
        toggleButton.setAttribute("aria-label", disabled ? "Enable timer sound" : "Disable timer sound");
    }

    function updateShareRoomButton(copied) {
        const shareButton = document.getElementById("shareRoomButton");
        if (!shareButton) {
            return;
        }

        shareButton.innerHTML = copied
            ? '<span class="room-action-icon" aria-hidden="true">✓</span>'
            : '<span class="room-action-icon" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false"><path d="M15 5a3 3 0 1 1 2.83 4H17l-6.2 3.1a3 3 0 0 1 0 1.8L17 17h.83A3 3 0 1 1 15 21a3 3 0 0 1 .17-1H15l-6.2-3.1a3 3 0 1 1 0-9.8L15 4h.17A3 3 0 0 1 15 5Z" fill="currentColor" /></svg></span>';
        shareButton.title = copied ? "Room ID copied" : "Copy room ID";
        shareButton.setAttribute("aria-label", copied ? "Room ID copied" : "Copy room ID");
        shareButton.classList.toggle("room-action-copied", copied);
    }

    async function copyTextToClipboard(text) {
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
        }

        const temporaryInput = document.createElement("input");
        temporaryInput.type = "text";
        temporaryInput.value = text;
        temporaryInput.setAttribute("readonly", "readonly");
        temporaryInput.style.position = "absolute";
        temporaryInput.style.left = "-9999px";
        document.body.appendChild(temporaryInput);
        temporaryInput.select();
        temporaryInput.setSelectionRange(0, temporaryInput.value.length);

        const succeeded = document.execCommand("copy");
        document.body.removeChild(temporaryInput);

        if (!succeeded) {
            throw new Error("Copy command was rejected.");
        }
    }

    function tryPlayFinishSound(ignoreDisabled = false) {
        if (!ignoreDisabled && notificationsDisabled()) {
            return;
        }

        const finishSound = getFinishSoundElement();
        if (!finishSound) {
            return;
        }

        finishSound.currentTime = 0;
        finishSound.play().catch(() => {
        });
    }

    function getTimerPresetElements() {
        return {
            container: document.getElementById("timerPresetRows"),
            addButton: document.getElementById("addTimerRowButton")
        };
    }

    function normalizeTimerMinutes(value) {
        return Math.max(0, parseInt(value, 10) || 0);
    }

    function normalizeTimerSeconds(value) {
        return Math.min(59, Math.max(0, parseInt(value, 10) || 0));
    }

    function setTimerRowIds(row, index) {
        const minutesInput = row.querySelector("[data-minutes-input]");
        const secondsInput = row.querySelector("[data-seconds-input]");
        const minuteLabel = row.querySelector("label[for^='timerMinInput-']");
        const secondLabel = row.querySelector("label[for^='timerSecInput-']");

        if (minutesInput) {
            const minutesId = `timerMinInput-${index}`;
            minutesInput.id = minutesId;
            if (minuteLabel) {
                minuteLabel.htmlFor = minutesId;
            }
        }

        if (secondsInput) {
            const secondsId = `timerSecInput-${index}`;
            secondsInput.id = secondsId;
            if (secondLabel) {
                secondLabel.htmlFor = secondsId;
            }
        }
    }

    function updateTimerPresetRowState() {
        const { container } = getTimerPresetElements();
        if (!container) {
            return;
        }

        const rows = Array.from(container.querySelectorAll("[data-timer-row]"));
        const hasSingleRow = rows.length <= 1;

        rows.forEach((row, index) => {
            setTimerRowIds(row, index);

            const removeButton = row.querySelector("[data-remove-timer-row]");
            if (!removeButton) {
                return;
            }

            removeButton.disabled = hasSingleRow;
            removeButton.classList.toggle("timer-preset-remove-hidden", hasSingleRow);
        });
    }

    function createTimerPresetRow(minutes = 5, seconds = 0) {
        const row = document.createElement("div");
        row.className = "timer-preset-row";
        row.setAttribute("data-timer-row", "");
        row.innerHTML = `
            <div class="timer-preset-field">
                <label class="small d-block" for="">Minutes</label>
                <input type="number" value="${normalizeTimerMinutes(minutes)}" min="0" class="form-control text-center timer-preset-input" data-minutes-input>
            </div>
            <div class="timer-preset-field">
                <label class="small d-block" for="">Seconds</label>
                <input type="number" value="${normalizeTimerSeconds(seconds)}" min="0" max="59" class="form-control text-center timer-preset-input" data-seconds-input>
            </div>
            <button class="btn btn-lg timer-preset-start" type="button" data-start-timer aria-label="Start timer" title="Start timer">
                <span class="timer-preset-start-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M8 6v12l10-6z" fill="currentColor" />
                    </svg>
                </span>
            </button>
            <button class="btn btn-lg timer-preset-remove" type="button" data-remove-timer-row aria-label="Remove timer row" title="Remove timer row">
                <span class="timer-action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </span>
            </button>
        `;

        return row;
    }

    function appendTimerPresetRow(minutes = 5, seconds = 0) {
        const { container } = getTimerPresetElements();
        if (!container) {
            return null;
        }

        const row = createTimerPresetRow(minutes, seconds);
        container.appendChild(row);
        updateTimerPresetRowState();
        return row;
    }

    function getTimerPresetValues(row) {
        const minutesInput = row?.querySelector("[data-minutes-input]");
        const secondsInput = row?.querySelector("[data-seconds-input]");

        if (!minutesInput || !secondsInput) {
            return null;
        }

        const minutes = normalizeTimerMinutes(minutesInput.value);
        const seconds = normalizeTimerSeconds(secondsInput.value);
        minutesInput.value = minutes.toString();
        secondsInput.value = seconds.toString();

        return { minutes, seconds };
    }

    updateNotificationToggleIcon();
    updateShareRoomButton(false);
    syncAlarmInputs();
    updateAlarmStatus();
    registerAudioUnlock();
    initializeAlarmSound();
    updateTimerPresetRowState();

    let shareRoomResetHandle = null;

    const shareRoomButton = document.getElementById("shareRoomButton");
    if (shareRoomButton) {
        shareRoomButton.addEventListener("click", async () => {
            if (!currentRoomId) {
                return;
            }

            try {
                const roomUrl = window.location.href;
                await copyTextToClipboard(roomUrl);
                updateShareRoomButton(true);

                if (shareRoomResetHandle) {
                    window.clearTimeout(shareRoomResetHandle);
                }

                shareRoomResetHandle = window.setTimeout(() => {
                    updateShareRoomButton(false);
                    shareRoomResetHandle = null;
                }, 1600);
            } catch {
                updateShareRoomButton(false);
            }
        });
    }

    const toggleButton = document.getElementById("notificationToggle");
    if (toggleButton) {
        toggleButton.addEventListener("click", async () => {
            const disabled = notificationsDisabled();
            setNotificationsDisabled(!disabled);
            updateNotificationToggleIcon();
            if (disabled) {
                await primeFinishSound();
            }
            updateAlarmStatus(disabled ? "Alarm sound enabled." : "Alarm sound disabled.");
        });
    }

    const alarmSaveButton = document.getElementById("alarmSaveButton");
    if (alarmSaveButton) {
        alarmSaveButton.addEventListener("click", async () => {
            await primeFinishSound();
            await saveAlarmSettings();
        });
    }

    const { input: alarmSoundInput, testButton: alarmSoundTestButton, resetButton: alarmSoundResetButton } = getAlarmSoundElements();

    if (alarmSoundInput) {
        alarmSoundInput.addEventListener("change", async (event) => {
            const selectedFile = event.target.files?.[0];
            if (!selectedFile) {
                return;
            }

            if (!selectedFile.type.startsWith("audio/")) {
                updateAlarmSoundStatus("Please choose a valid audio file.");
                alarmSoundInput.value = "";
                return;
            }

            try {
                await saveStoredAlarmSound(selectedFile);
                await applyStoredAlarmSound({
                    blob: selectedFile,
                    name: selectedFile.name,
                    type: selectedFile.type
                });
                await primeFinishSound();
                tryPlayFinishSound(true);
            } catch {
                setFinishSoundSource(defaultFinishSoundUrl);
                updateAlarmSoundStatus("Could not save that sound locally. Using default alarm sound.");
            } finally {
                alarmSoundInput.value = "";
            }
        });
    }

    if (alarmSoundTestButton) {
        alarmSoundTestButton.addEventListener("click", async () => {
            const primed = await primeFinishSound();
            if (!primed) {
                updateAlarmSoundStatus("Sound preview is blocked until you interact with the page.");
                return;
            }

            tryPlayFinishSound(true);
        });
    }

    if (alarmSoundResetButton) {
        alarmSoundResetButton.addEventListener("click", async () => {
            try {
                await clearStoredAlarmSound();
                await applyStoredAlarmSound(null);
                await primeFinishSound();
            } catch {
                updateAlarmSoundStatus("Could not remove the saved personal sound.");
            }
        });
    }

    // 2. Only run the SignalR logic if we are actually in a room
    if (currentRoomId) {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/timerHub")
            .withAutomaticReconnect()
            .build();

        let previousTotalSeconds = null;
        let hasSeenPositiveTime = false;
        let alarmTriggered = false;

        function updateTimerDisplayState(display, totalSeconds) {
            if (!display) {
                return;
            }

            if (totalSeconds === 0) {
                display.classList.add("timer-finished");
            } else {
                display.classList.remove("timer-finished");
            }
        }

        function updateRoomUserCount(count) {
            const roomUserCount = document.getElementById("roomUserCount");
            if (!roomUserCount) {
                return;
            }

            roomUserCount.innerText = String(Math.max(0, count ?? 0));
        }

        // Listeners
        connection.on("ReceiveTime", (totalSeconds) => {
            const m = Math.floor(totalSeconds / 60).toString().padStart(2, '0');
            const s = (totalSeconds % 60).toString().padStart(2, '0');
            const display = document.getElementById("timerDisplay");
            if (display) {
                display.innerText = `${m}:${s}`;
            }

            updateTimerDisplayState(display, totalSeconds);

            if (totalSeconds > 0) {
                hasSeenPositiveTime = true;
            }

            const alarmThresholdInSeconds = getAlarmThresholdInSeconds();
            const crossedAlarmThreshold =
                hasSeenPositiveTime &&
                !alarmTriggered &&
                totalSeconds > 0 &&
                totalSeconds <= alarmThresholdInSeconds &&
                (previousTotalSeconds === null || previousTotalSeconds > alarmThresholdInSeconds);

            if (crossedAlarmThreshold) {
                alarmTriggered = true;
                tryPlayFinishSound();
                tryShowBrowserNotification(totalSeconds);
            }

            if (previousTotalSeconds !== null && totalSeconds > previousTotalSeconds) {
                alarmTriggered = false;
            }

            if (totalSeconds === 0) {
                alarmTriggered = false;
            }

            previousTotalSeconds = totalSeconds;
        });

        connection.on("RoomUserCount", (count) => {
            updateRoomUserCount(count);
        });

        connection.on("Message", (message) => {
            if (message === "Timer Reset") {
                hasSeenPositiveTime = false;
                previousTotalSeconds = 0;
                alarmTriggered = false;
            }
        });

        connection.on("TimerFinished", () => {
            const display = document.getElementById("timerDisplay");
            if (display) {
                display.innerText = "00:00";
            }

            updateTimerDisplayState(display, 0);

            if (getAlarmThresholdInSeconds() === 0 && hasSeenPositiveTime && !alarmTriggered) {
                alarmTriggered = true;
                tryPlayFinishSound();
                tryShowBrowserNotification(0);
            }

            hasSeenPositiveTime = false;
            previousTotalSeconds = 0;
            alarmTriggered = false;
        });

        // Connection indicator
        function setIndicator(state) {
            const indicator = document.getElementById("signalrIndicator");
            if (!indicator) return;
            indicator.className = "signalr-indicator";
            if (state === "connected") {
                indicator.classList.add("signalr-connected");
                indicator.title = "Connected";
            } else if (state === "reconnecting") {
                indicator.classList.add("signalr-reconnecting");
                indicator.title = "Reconnecting...";
            } else {
                indicator.classList.add("signalr-disconnected");
                indicator.title = "Disconnected";
            }
        }

        connection.onreconnecting(() => setIndicator("reconnecting"));
        connection.onreconnected(async () => {
            setIndicator("connected");
            await connection.invoke("JoinSession", currentRoomId);
        });
        connection.onclose(() => setIndicator("disconnected"));

        // Start Connection
        async function start() {
            try {
                await connection.start();
                setIndicator("connected");
                await connection.invoke("JoinSession", currentRoomId);
            } catch (err) {
                console.error(err);
                setIndicator("disconnected");
            }
        }

        async function startTimerWithValues(minutes, seconds) {
            hasSeenPositiveTime = ((minutes * 60) + seconds) > 0;
            alarmTriggered = false;
            previousTotalSeconds = null;
            await primeFinishSound();
            await connection.invoke("StartTimer", currentRoomId, minutes, seconds);
        }

        const { container: timerPresetContainer, addButton: addTimerRowButton } = getTimerPresetElements();

        if (addTimerRowButton) {
            addTimerRowButton.addEventListener("click", () => {
                const row = appendTimerPresetRow();
                const minutesInput = row?.querySelector("[data-minutes-input]");
                if (minutesInput) {
                    minutesInput.focus();
                    minutesInput.select();
                }
            });
        }

        if (timerPresetContainer) {
            timerPresetContainer.addEventListener("click", async (event) => {
                const startButton = event.target.closest("[data-start-timer]");
                if (startButton) {
                    const row = startButton.closest("[data-timer-row]");
                    const values = getTimerPresetValues(row);
                    if (!values) {
                        return;
                    }

                    await startTimerWithValues(values.minutes, values.seconds);
                    return;
                }

                const removeButton = event.target.closest("[data-remove-timer-row]");
                if (!removeButton) {
                    return;
                }

                const rows = timerPresetContainer.querySelectorAll("[data-timer-row]");
                if (rows.length <= 1) {
                    return;
                }

                removeButton.closest("[data-timer-row]")?.remove();
                updateTimerPresetRowState();
            });
        }

        window.handlePause = async function() {
            await primeFinishSound();
            await connection.invoke("TogglePause", currentRoomId);
        };

        window.handleReset = async function() {
            hasSeenPositiveTime = false;
            previousTotalSeconds = 0;
            alarmTriggered = false;
            await primeFinishSound();
            await connection.invoke("ResetTimer", currentRoomId);
        };

        window.handleAdjustTime = async function(deltaSeconds) {
            await connection.invoke("AdjustTime", currentRoomId, deltaSeconds);
        };

        start();
    }
</script>

<audio id="timerFinishedSound" preload="auto"></audio>